{
  "name": "viseo-metadata-service",
  "version": "0.1.0",
  "private": true,
  "description": "Redis-first multi-tenant metadata service with TMDB-primary lookup/search, official IMDb enrichment/fallback, and background refresh",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "swc src -d dist --config-file .swcrc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:infra": "vitest run tests/integration",
    "test:redis": "vitest run tests/integration/real-redis.integration.test.ts",
    "test:performance": "vitest run --dir tests/performance",
    "test:providers:live": "node --env-file=.env scripts/live-provider-smoke.mjs",
    "test:watch": "vitest",
    "fixtures:manual": "node --env-file=.env scripts/manual-test-fixtures/run-fixtures.mjs",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down --remove-orphans",
    "compose:logs": "docker compose logs -f",
    "compose:smoke": "node --env-file=.env scripts/live-compose-smoke.mjs",
    "start": "node dist/main.js",
    "start:api": "node dist/main.js",
    "start:worker": "node dist/worker.js"
  },
  "dependencies": {
    "@aws-sdk/client-dataexchange": "^3.922.0",
    "bullmq": "^5.56.1",
    "express": "^5.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.3.2",
    "prom-client": "^15.1.3",
    "swagger-ui-dist": "^5.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.7.14",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "ioredis-mock": "^8.9.0",
    "supertest": "^7.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
