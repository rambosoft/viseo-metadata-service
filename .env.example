NODE_ENV=development
PORT=3000
REQUEST_BODY_LIMIT_BYTES=16384
LOG_LEVEL=info

REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=md

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

AUTH_SERVICE_URL=https://auth.example.com
AUTH_TIMEOUT_MS=3000
AUTH_CACHE_TTL_SECONDS=300

MANUAL_FIXTURE_AUTH_PORT=4010
MANUAL_FIXTURE_BIND_HOST=127.0.0.1
MANUAL_FIXTURE_TOKEN=demo-token
MANUAL_FIXTURE_AUTH_MODE=success
MANUAL_FIXTURE_TENANT_ID=tenant_demo
MANUAL_FIXTURE_PRINCIPAL_ID=principal_demo
MANUAL_FIXTURE_SCOPES=metadata:read
MANUAL_FIXTURE_EXPIRES_IN_SECONDS=3600

TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
TMDB_API_KEY=replace-me
TMDB_TIMEOUT_MS=5000
# IMDb is optional. Uncomment and fill these only if you want IMDb fallback and rating enrichment.
# IMDB_API_URL=https://api-fulfill.dataexchange.us-east-1.amazonaws.com/v1
# IMDB_API_KEY=
# IMDB_TIMEOUT_MS=5000
# IMDB_AWS_REGION=us-east-1
# IMDB_DATA_SET_ID=
# IMDB_REVISION_ID=
# IMDB_ASSET_ID=
# AWS_PROFILE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
MOVIE_CACHE_TTL_SECONDS=3600
TV_CACHE_TTL_SECONDS=3600
MEDIA_STALE_SERVE_WINDOW_SECONDS=86400
CANONICAL_RECORD_TTL_SECONDS=604800
LOOKUP_SINGLEFLIGHT_TTL_SECONDS=5
LOOKUP_SINGLEFLIGHT_WAIT_MS=500
SEARCH_CACHE_TTL_SECONDS=900
SEARCH_INDEX_TTL_SECONDS=21600
REFRESH_QUEUE_NAME=metadata-refresh
REFRESH_JOB_ATTEMPTS=3
REFRESH_JOB_BACKOFF_MS=1000
REFRESH_WORKER_CONCURRENCY=4
REFRESH_DEDUP_TTL_SECONDS=60
WORKER_SHUTDOWN_TIMEOUT_MS=30000

SMOKE_API_BASE_URL=http://127.0.0.1:3000
SMOKE_AUTH_TOKEN=demo-token
SMOKE_MOVIE_TMDB_ID=550
SMOKE_MOVIE_IMDB_ID=tt0137523
SMOKE_TV_TMDB_ID=1396
SMOKE_TV_IMDB_ID=tt0903747
SMOKE_IMDB_FALLBACK_MOVIE_ID=
SMOKE_IMDB_FALLBACK_TV_ID=
